# Copy to .env and fill in. Never commit the real .env.
# With NO Supabase keys set, the app runs in mock mode (fully playable, scores
# not persisted, placeholder leaderboard). Add the keys to go live.

# --- Supabase (client-safe) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server only — never exposed to the browser, used by seed script) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Sign-in: shared guest code (OPTIONAL) ---
# Leave UNSET for the simplest flow: tap your name, confirm, you're in.
# Set it to require one shared code (printed on the invite) to keep strangers out.
# NEXT_PUBLIC_EVENT_CODE=1234

# --- Email (only if you later add email-OTP sign-in; not used by name-pick) ---
# RESEND_API_KEY=

# --- Event config ---
# Unlock schedule (timezone is fixed to Europe/Paris in code). Defaults to the
# real launch date; override only for testing.
# NEXT_PUBLIC_LAUNCH_DATE=2026-07-31
# Dev/preview escape hatch: open every game regardless of date. NEVER in prod.
# NEXT_PUBLIC_UNLOCK_ALL=1
# Local dev uses localhost; production is https://wedding.cdbradley.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
