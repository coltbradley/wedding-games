# Copy to .env and fill in. Never commit the real .env.

# --- Supabase (client-safe) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server only — never exposed to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Email provider for the OTP code (wired into Supabase Auth SMTP) ---
# Use one. Resend shown; Postmark equivalent works too.
RESEND_API_KEY=

# --- Name-pick fallback ---
# Shared event code printed on the invite / pinned in WhatsApp.
EVENT_CODE=

# --- Event config ---
APP_TIMEZONE=Europe/Paris
LAUNCH_DATE=2026-07-31
# Local dev uses localhost; production is https://wedding.graphite.productions
NEXT_PUBLIC_APP_URL=http://localhost:3000
